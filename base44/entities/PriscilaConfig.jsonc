{
  "name": "PriscilaConfig",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Nome da configuração"
    },
    "isActive": {
      "type": "boolean",
      "default": true,
      "description": "Se está ativa"
    },
    "priscilaVersion": {
      "type": "string",
      "description": "Versão da PRISCILA"
    },
    "llmPromptTemplate": {
      "type": "string",
      "description": "Template do prompt para a LLM"
    },
    "llmResponseJsonSchema": {
      "type": "object",
      "description": "JSON Schema da resposta esperada da LLM"
    },
    "validationRules": {
      "type": "object",
      "description": "Regras do Validador (Etapa 1)"
    },
    "riskClassificationRules": {
      "type": "object",
      "description": "Regras do Classificador (Etapa 2)"
    },
    "decisionRules": {
      "type": "object",
      "description": "Regras do Decisor (Etapa 3)"
    },
    "benchmarksConcorrentes": {
      "type": "object",
      "description": "Dados de benchmark"
    }
  },
  "required": [
    "name",
    "isActive",
    "priscilaVersion"
  ]
}