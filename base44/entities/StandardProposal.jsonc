{
  "name": "StandardProposal",
  "type": "object",
  "properties": {
    "templateName": {
      "type": "string"
    },
    "segment": {
      "type": "string",
      "enum": [
        "Educa\u00e7\u00e3o",
        "Infoprodutos",
        "E-commerce",
        "SaaS",
        "Gateway",
        "Marketplace",
        "Dropshipping",
        "MPE",
        "Plataformas Verticais",
        "Link de Pagamento"
      ]
    },
    "description": {
      "type": "string"
    },
    "businessSubCategory": {
      "type": "string",
      "enum": [
        "educacao",
        "infoprodutos",
        "ecommerce",
        "saas",
        "gateway",
        "marketplace",
        "mpe",
        "dropshipping",
        "plataformas_verticais",
        "link_pagamento"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "rascunho",
        "ativa",
        "inativa"
      ],
      "default": "rascunho"
    },
    "isDefaultForSegment": {
      "type": "boolean",
      "default": false
    },
    "clienteNome": {
      "type": "string"
    },
    "clienteCnpj": {
      "type": "string"
    },
    "clienteContato": {
      "type": "string"
    },
    "clienteTelefone": {
      "type": "string"
    },
    "clienteEmail": {
      "type": "string"
    },
    "chosenPartnerId": {
      "type": "string"
    },
    "chosenPartnerName": {
      "type": "string"
    },
    "rates": {
      "type": "object"
    },
    "tokenPublico": {
      "type": "string"
    },
    "publicSlug": {
      "type": "string",
      "description": "Slug p\u00fablico personalizado para URL amig\u00e1vel"
    },
    "codigo": {
      "type": "string"
    },
    "terms": {
      "type": "string"
    },
    "validUntil": {
      "type": "string",
      "format": "date-time"
    },
    "responsavelId": {
      "type": "string"
    },
    "responsavelNome": {
      "type": "string"
    }
  },
  "required": [
    "templateName",
    "segment"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {
      "user_condition": {
        "role": "admin"
      }
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}